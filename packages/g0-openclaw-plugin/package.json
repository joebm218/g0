{
  "name": "@guard0/g0-openclaw-plugin",
  "version": "1.0.2",
  "description": "g0 security plugin for OpenClaw — injection detection, PII redaction, tool gating, and daemon telemetry",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "openclaw": {
    "extensions": ["./dist/index.js"]
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "tsc"
  },
  "files": ["dist", "openclaw.plugin.json"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/guard0-ai/g0.git",
    "directory": "packages/g0-openclaw-plugin"
  },
  "homepage": "https://guard0.ai/g0",
  "author": "Rakshan AI Inc. (dba Guard0)",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "keywords": ["openclaw", "plugin", "security", "guard0", "g0", "injection-detection", "pii-redaction", "ai-agent", "ai-security"],
  "engines": {
    "node": ">=20.0.0"
  }
}
