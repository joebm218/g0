{
  "name": "@guard0/g0",
  "version": "1.1.0",
  "description": "AI Agent Security Scanner — the Snyk for AI agents",
  "type": "module",
  "bin": {
    "g0": "./dist/bin/g0.js"
  },
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts"
    }
  },
  "files": [
    "dist",
    "templates",
    "src/rules/**/*.yaml"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ bin/",
    "typecheck": "tsc --noEmit",
    "g0": "tsx bin/g0.ts",
    "prepublishOnly": "tsup && vitest run"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/guard0-ai/g0.git"
  },
  "homepage": "https://guard0.ai",
  "bugs": {
    "url": "https://github.com/guard0-ai/g0/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "ai",
    "agent",
    "security",
    "scanner",
    "owasp",
    "langchain",
    "crewai",
    "mcp",
    "openai",
    "vercel-ai",
    "bedrock",
    "autogen",
    "sast",
    "dast",
    "ai-security"
  ],
  "author": "Guard0.ai",
  "license": "Apache-2.0",
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "glob": "^11.0.0",
    "handlebars": "^4.7.8",
    "ignore": "^6.0.2",
    "ora": "^8.1.0",
    "yaml": "^2.5.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.2.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "optionalDependencies": {
    "tree-sitter": "0.21.1",
    "tree-sitter-python": "0.23.4",
    "tree-sitter-typescript": "0.23.2",
    "tree-sitter-javascript": "0.23.1"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
