# ─── Guard0 Platform (for --upload and g0 auth/daemon) ───
# Point CLI at your local platform (default: https://cloud.guard0.ai)
G0_PLATFORM_URL=http://localhost:3000

# Auth — use ONE of these methods:

# Option 1: API key (create in platform Settings → API Keys)
G0_API_TOKEN=g0_c280bbf462a961db9f03f56f18b95d31701e59b8a7fade9121701af8dc11d7b1

# Option 2: Device flow (runs browser-based OAuth)
# G0_AUTH_URL=http://localhost:3000
# Then run: g0 auth login

# ─── AI Analysis (for --ai flag) ─────────────────────────
# Needed only for: g0 scan --ai, g0 test --ai
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
